@model IEnumerable<Platform.WebClient.Models.DocumentViewModel>

@{
    ViewData["Title"] = "Documents";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <p>
        <a asp-action="CreateSample" class="btn btn-primary">Create sample document</a>
    </p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Content</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model)
            {
                <tr>
                    <td>@doc.Id</td>
                    <td>@doc.Title</td>
                    <td>@doc.Content</td>
                </tr>
            }
        </tbody>
    </table>
</div>

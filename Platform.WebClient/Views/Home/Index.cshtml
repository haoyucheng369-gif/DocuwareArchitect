@model Platform.WebClient.Models.DocumentsPageViewModel

@{
    ViewData["Title"] = "Documents";
}

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="mb-1">@ViewData["Title"]</h1>
            <div class="text-muted">Signed in as @User.Identity?.Name</div>
        </div>
        <a asp-action="CreateSample" class="btn btn-primary">Create sample document</a>
    </div>

    <h2 class="h5">Standard documents</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Content</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model.Documents)
            {
                <tr>
                    <td>@doc.Id</td>
                    <td>@doc.Title</td>
                    <td>@doc.Content</td>
                </tr>
            }
        </tbody>
    </table>

    <h2 class="h5 mt-4">Confidential documents</h2>
    @if (!string.IsNullOrWhiteSpace(Model.ConfidentialAccessMessage))
    {
        <div class="alert alert-warning">@Model.ConfidentialAccessMessage</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Content</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model.ConfidentialDocuments)
                {
                    <tr>
                        <td>@doc.Id</td>
                        <td>@doc.Title</td>
                        <td>@doc.Content</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
